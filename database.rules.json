{
  "rules": {
    ".read": false,
    ".write": false,

    "models": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    },

    "series": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    },

    "subcategories": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    },

    "users": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["phone", "email"],
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },

    "admins": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && auth.uid == $uid"
      }
    },

    "jobs": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["status", "created_at", "type", "rider_id", "agent_name", "uid", "cust_email", "cust_phone", "kyc_verified_at"],
      "$jobId": {
        ".read": true,
        ".write": "auth != null && (data.child('rider_id').val() === auth.uid || newData.child('rider_id').val() === auth.uid)",
        "chats": {
          ".read": "auth != null",
          ".write": "auth != null"
        },

        "kyc": {
          ".validate": false
        },

        "kyc_verified_at": {
          ".validate": "!data.exists() && newData.isNumber() && newData.val() <= now + 300000"
        },

        "kyc_method": {
          ".validate": "!data.exists() && newData.isString() && (newData.val() === 'photo' || newData.val() === 'typed_fallback')"
        }
      }
    },

    "jobs_kyc": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["verified_at"],
      "$jobId": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).child('role').val() === 'admin' || root.child('jobs').child($jobId).child('rider_id').val() === auth.uid)",
        ".write": "auth != null && !data.exists() && root.child('jobs').child($jobId).child('rider_id').val() === auth.uid",
        ".validate": "newData.hasChildren(['method', 'id_number', 'id_address', 'verified_at', 'verified_by_rider_uid', 'verified_by_rider_name'])",
        "method": { ".validate": "newData.isString() && (newData.val() === 'photo' || newData.val() === 'typed_fallback')" },
        "id_number": { ".validate": "newData.isString() && newData.val().length === 13" },
        "id_address": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 500" },
        "verified_at": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
        "verified_by_rider_uid": { ".validate": "newData.isString() && newData.val() === auth.uid" },
        "verified_by_rider_name": { ".validate": "newData.isString() && newData.val().length > 0" },
        "id_card_url": { ".validate": "newData.isString() && newData.val().length > 0" },
        "id_with_device_url": { ".validate": "newData.isString() && newData.val().length > 0" },
        "holder_url": { ".validate": "newData.isString() && newData.val().length > 0" },
        "signature_url": { ".validate": "newData.isString() && newData.val().length > 0" },
        "fallback_reason": { ".validate": "newData.isString()" },
        "fallback_detail": { ".validate": "newData.isString()" },
        "id_name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" },
        "id_dob": { ".validate": "newData.isString() && newData.val().length <= 30" },
        "id_issued_at": { ".validate": "newData.isString() && newData.val().length <= 30" },
        "id_expires_at": { ".validate": "newData.isString() && newData.val().length <= 30" },
        "$other": { ".validate": false }
      }
    },

    "jobs_amendments": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["status", "job_id", "requested_at"],
      "$amendmentId": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).child('role').val() === 'admin' || root.child('jobs').child(data.child('job_id').val()).child('rider_id').val() === auth.uid)",
        ".write": "auth != null && (!data.exists() ? root.child('jobs').child(newData.child('job_id').val()).child('rider_id').val() === auth.uid : (root.child('admins').child(auth.uid).child('role').val() === 'admin' || root.child('jobs').child(data.child('job_id').val()).child('rider_id').val() === auth.uid))",
        ".validate": "newData.hasChildren(['job_id', 'type', 'requested_at', 'requested_by_rider_uid', 'requested_by_rider_name', 'before', 'status'])",
        "job_id": { ".validate": "newData.isString() && newData.val().length > 0" },
        "type": { ".validate": "newData.isString() && newData.val() === 'device_mismatch'" },
        "requested_at": { ".validate": "newData.isNumber() && newData.val() <= now + 300000" },
        "requested_by_rider_uid": { ".validate": "newData.isString() && (data.exists() || newData.val() === auth.uid)" },
        "requested_by_rider_name": { ".validate": "newData.isString() && newData.val().length > 0" },
        "rider_note": { ".validate": "newData.isString() && newData.val().length <= 500" },
        "evidence_urls": {
          ".validate": "newData.hasChildren()",
          "$idx": { ".validate": "newData.isString() && newData.val().length > 0" }
        },
        "before": {
          ".validate": "newData.hasChildren(['devices', 'final_price'])",
          "devices": { ".validate": "newData.hasChildren()" },
          "final_price": { ".validate": "newData.isNumber()" }
        },
        "after": {
          ".validate": "newData.hasChildren(['devices', 'final_price'])",
          "devices": { ".validate": "newData.hasChildren()" },
          "final_price": { ".validate": "newData.isNumber()" }
        },
        "status": { ".validate": "newData.isString() && (newData.val() === 'pending' || newData.val() === 'approved' || newData.val() === 'rejected' || newData.val() === 'consented' || newData.val() === 'applied' || newData.val() === 'cancelled')" },
        "reviewed_at": { ".validate": "newData.isNumber()" },
        "reviewed_by_admin_uid": { ".validate": "newData.isString()" },
        "reviewed_by_admin_name": { ".validate": "newData.isString()" },
        "admin_note": { ".validate": "newData.isString() && newData.val().length <= 500" },
        "reject_action": { ".validate": "newData.isString() && (newData.val() === 'continue_original' || newData.val() === 'cancel_job' || newData.val() === 'wait_admin_call')" },
        "consented_at": { ".validate": "newData.isNumber()" },
        "consent_method": { ".validate": "newData.isString() && (newData.val() === 'signature' || newData.val() === 'otp' || newData.val() === 'verbal')" },
        "consent_signature_url": { ".validate": "newData.isString() && newData.val().length > 0" },
        "applied_at": { ".validate": "newData.isNumber()" },
        "escalated_at": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },

    "jobs_archived": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["status", "created_at"]
    },

    "staff": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    },

    "sales": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["sold_at", "status"]
    },

    "customers": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    },

    "riders": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).child('role').val() === 'admin')",
        ".validate": "!newData.hasChildren(['approval_status', 'suspend_reason']) || root.child('admins').child(auth.uid).child('role').val() === 'admin'"
      }
    },

    "admin_fcm_tokens": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    },

    "base_pricing": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    },

    "settings": {
      "branches": {
        ".read": true
      },
      "store": {
        ".read": true
      },
      "condition_sets": {
        ".read": true
      },
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    },

    "claims": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    },

    "daily_expenses": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    },

    "coupons": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    },

    "reviews": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "branches": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    },

    "notifications": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["target_uid"],
      "$notificationId": {
        ".read": "auth != null && (data.child('target_uid').val() === auth.uid || root.child('admins').child(auth.uid).child('role').val() === 'admin')"
      }
    },

    "draft_carts": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },

    "blogs": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["slug", "created_at"]
    },

    "price_ledger": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    },

    "transactions": {
      ".read": "auth != null && (root.child('admins').child(auth.uid).child('role').val() === 'admin' || (query.orderByChild === 'rider_id' && query.equalTo === auth.uid))",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["timestamp", "rider_id"]
    },

    "articles": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    },

    "assessment_events": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".write": true,
      ".indexOn": ["timestamp", "event_type", "model_id"]
    },

    "rate_limits": {
      ".read": false,
      ".write": false
    },

    "security_logs": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".write": false
    }
  }
}
