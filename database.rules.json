{
  "rules": {
    ".read": false,
    ".write": false,
    "models": {
      ".read": true,
      ".write": "auth != null"
    },
    "series": {
      ".read": true,
      ".write": "auth != null"
    },
    "subcategories": {
      ".read": true,
      ".write": "auth != null"
    },
    "users": {
      ".read": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "jobs": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["status", "created_at", "type", "rider_id", "agent_name", "uid", "cust_email", "cust_phone"]
    },
    "jobs_archived": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["status", "created_at"]
    },
    "staff": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "sales": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["sold_at", "status"]
    },
    "customers": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "riders": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "admin_fcm_tokens": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "base_pricing": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "settings": {
      "branches": {
        ".read": true,
        ".write": "auth != null"
      },
      "store": {
        ".read": true,
        ".write": "auth != null"
      },
      "condition_sets": {
        ".read": true,
        ".write": "auth != null"
      },
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "claims": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "daily_expenses": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "coupons": {
      ".read": true,
      ".write": "auth != null"
    },
    "reviews": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "branches": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "notifications": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["target_uid"]
    },
    "draft_carts": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "blogs": {
      ".read": true,
      ".indexOn": ["slug"]
    },
    "admins": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid"
      }
    },
    "transactions": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["timestamp", "ref_job_id", "rider_id", "type", "category"]
    }
  }
}
