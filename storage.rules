rules_version = '2';

// Firebase Storage rules for bkk-apple-tradein.
//
// Default deny. Specific paths grant the minimum access each surface
// needs. The KYC paths are write-once (audit integrity) and gated to
// authenticated users only — no public download links can be guessed.

service firebase.storage {
  match /b/{bucket}/o {

    // ─── KYC evidence (PR-KYC-isolate) ─────────────────────────────
    // ภาพถ่ายบัตรประชาชน / บัตรคู่เครื่อง / ลูกค้าถือบัตร / ลายเซ็น
    // เก็บที่จุดรับเครื่องโดยไรเดอร์ — ห้ามแก้/ลบ และห้ามดูถ้า
    // ไม่ได้ login. (admin role check ทำที่ RTDB layer แทน — Storage
    // rules ไม่สามารถ query RTDB ได้โดยตรง)
    match /jobs/{jobId}/kyc/{filename} {
      // อ่านได้เฉพาะ user ที่ login — token URL ของ Firebase ก็ยัง
      // ใช้ได้ (signed token) แต่ direct SDK access ต้อง auth
      allow read: if request.auth != null;
      // เขียนใหม่ได้เฉพาะตอนยังไม่มีไฟล์ — ห้าม overwrite/replace
      allow create: if request.auth != null && resource == null;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Inspection photos ─────────────────────────────────────────
    // ไรเดอร์ถ่ายตอน QC + admin Internal QC. เก็บเป็นหลักฐานสภาพ
    // เครื่อง — write ได้ระหว่างจ๊อบยังเปิด, ลบได้ผ่าน admin SDK
    match /jobs/{jobId}/inspection/{filename=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Chat attachments ──────────────────────────────────────────
    match /jobs/{jobId}/chats/{filename=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Discrepancy report attachments ────────────────────────────
    match /jobs/{jobId}/discrepancy/{filename=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Amendment evidence + customer consent signature (PR-AMEND v2)
    // ภาพประกอบจาก rider เวลาแจ้งปัญหาหน้างาน + ลายเซ็นลูกค้าเวลา
    // ยืนยัน contractual amendment. ใช้ opaque UUID filename — guess ไม่ได้
    // RTDB layer (jobs_amendments validate rules) gates ใครเขียน record
    // ได้ ส่วน Storage layer แค่ require auth. สอดคล้องกับ KYC pattern.
    match /jobs/{jobId}/amendments/{filename=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Device verification photos (Vision OCR pipeline) ──────────
    // ภาพถ่ายหน้าจอ Settings (About / Battery / Find My) ที่ rider
    // ถ่ายตอนตรวจสอบเครื่องเบื้องต้น
    match /jobs/{jobId}/verification/{filename=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Payment / payout slips ────────────────────────────────────
    // /slips/tradein/* — แอดมินอัปโหลดสลิปโอนเงินค่ารับซื้อให้ลูกค้า
    // /slips/withdrawals/* — แอดมินอัปโหลดสลิปเบิกเงินไรเดอร์
    // เป็นภาพภายใน — auth user เท่านั้นเข้าได้ (admin role check ทำที่
    // RTDB layer ตอนเขียน /transactions เพิ่ม)
    match /slips/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── B2B order attachments ─────────────────────────────────────
    // ไฟล์แนบของลูกค้า B2B (PO, ใบเสนอราคา, ฯลฯ)
    match /b2b_attachments/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Rider onboarding documents ────────────────────────────────
    // บัตรประชาชน + ใบขับขี่ + selfie ของไรเดอร์ตอน register —
    // คนละ scope กับ KYC ของลูกค้า
    match /riders/{riderId}/{filename=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == riderId;
    }

    // ─── Product / model images ────────────────────────────────────
    match /models/{filename=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /series/{filename=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── Catch-all default deny ────────────────────────────────────
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
